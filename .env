# .env - fill these values
DISCORD_TOKEN=MTMyMjU4MTY5OTM4MDM3OTcwOQ.GF4bzd.CHttD__0U7FGyUIo4a6wBJbIN_gchmtIDm0wTc
# Bot prefix, e.g. ! or ?
BOT_PREFIX=!

# Name of the moderator role the bot will recognize
MOD_ROLE_NAME=Moderator

# Ticket category name (the bot will create if missing and it has permission)
TICKET_CATEGORY_NAME=Tickets

# Anti-spam / automatic slowdown settings:
# Number of messages in window to trigger auto-slowdown
SLOW_THRESHOLD=5
# Window size (seconds) to count messages
SLOW_WINDOW=7
# How many seconds of slowmode to set when triggered
SLOW_MODE_DURATION=10
# How many seconds to keep that slowmode before restoring the original value
SLOW_RESET_SECONDS=60
